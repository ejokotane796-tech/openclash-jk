# ================= 4. 路由与分流规则 =================
rules:
  # 广告拦截
  - RULE-PROVIDER,Advertising,REJECT
  
  # AI 服务
  - RULE-PROVIDER,Claude,Claude
  - RULE-PROVIDER,Gemini,Gemini
  - RULE-PROVIDER,AI,AI
  
  # 媒体娱乐
  - RULE-PROVIDER,YouTube,YouTube
  - RULE-PROVIDER,Netflix,Netflix
  - RULE-PROVIDER,Disney,Disney+
  - DOMAIN-SUFFIX,litix.io,Max
  - DOMAIN-SUFFIX,discomax.com,Max
  - DOMAIN-SUFFIX,brightline.tv,Max
  - RULE-PROVIDER,HBO,Max
  - RULE-PROVIDER,Spotify,Spotify
  
  # 社交与通讯
  - RULE-PROVIDER,Telegram,Telegram
  - RULE-PROVIDER,Instagram,Instagram
  - RULE-PROVIDER,Twitter,Twitter
  - RULE-PROVIDER,Facebook,Facebook
  - RULE-PROVIDER,TikTok,TikTok
  
  # 支付与电商
  - RULE-PROVIDER,PayPal,PayPal
  - RULE-PROVIDER,Amazon,Amazon
  
  # 游戏平台
  - RULE-PROVIDER,Sony,游戏平台
  - RULE-PROVIDER,Nintendo,游戏平台
  - RULE-PROVIDER,Epic,游戏平台
  - RULE-PROVIDER,SteamCN,游戏平台
  - RULE-PROVIDER,Steam,游戏平台
  - RULE-PROVIDER,Game,游戏平台
  
  # 基础大厂服务

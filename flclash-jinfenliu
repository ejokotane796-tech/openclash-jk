# Flclash (Clash Meta / Mihomo) 分流与分组覆写规则
# ---------------------------------------------------

proxy-groups:
  # ================= 1. 策略分组 =================
  - name: Proxy # 兜底代理分组（替代 SR 中的 PROXY）
    type: select
    include-all: true

  - name: Claude
    type: select
    proxies: [新加坡AI]

  - name: Gemini
    type: select
    proxies: [新加坡AI]

  - name: AI
    type: select
    proxies: [新加坡AI]

  - name: YouTube
    type: select
    proxies: [Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]

  - name: Netflix
    type: select
    proxies: [Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]

  - name: Disney+
    type: select
    proxies: [Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]

  - name: TikTok
    type: select
    proxies: [日本节点, POL日本, 日本fallback]

  - name: Instagram
    type: select
    proxies: [日本节点, POL日本, 日本fallback]

  - name: Twitter
    type: select
    proxies: [日本节点, POL日本, 日本fallback]

  - name: Spotify
    type: select
    proxies: [DIRECT, Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]

  - name: Telegram
    type: select
    proxies: [Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]

  - name: Facebook
    type: select
    proxies: [住宅IP]

  - name: PayPal
    type: select
    proxies: [住宅IP]

  - name: Amazon
    type: select
    proxies: [DIRECT, Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点, 住宅IP]

  - name: Max
    type: select
    proxies: [Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]

  - name: 苹果服务
    type: select
    proxies: [DIRECT, Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]

  - name: 谷歌服务
    type: select
    proxies: [Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点, 新加坡AI, POL日本]

  - name: 微软服务
    type: select
    proxies: [DIRECT, Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]

  - name: 哔哩哔哩
    type: select
    proxies: [DIRECT, Proxy, 香港节点, 台湾节点]

  - name: 游戏平台
    type: select
    proxies: [DIRECT, Proxy, 香港节点, 台湾节点, 日本节点, 新加坡节点, 韩国节点, 美国节点]


  # ================= 2. 节点筛选分组（使用正则匹配自动拉取节点） =================
  - name: 香港节点
    type: url-test
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    include-all: true
    filter: "(?i)🇭🇰|HK|Hong|香港|深港|沪港|京港|港"

  - name: 台湾节点
    type: url-test
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    include-all: true
    filter: "(?i)🇹🇼|TW|TWN|Taiwan|Taipei|taiwan|台湾|台灣|台北|台中|新北|彰化"

  - name: 日本节点
    type: url-test
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    include-all: true
    filter: "(?i)🇯🇵|JP|Japan|japan|Tokyo|tokyo|日本|东京|大阪|京日|苏日|沪日|上日|川日|深日|广日"

  - name: POL日本
    type: url-test
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    include-all: true
    filter: "(?i)日本"

  - name: 日本fallback
    type: fallback
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    include-all: true
    filter: "(?i)日本-优化|日本-优化2|日本-优化3|日本JP-A|日本JP-HY2"

  - name: 新加坡节点
    type: url-test
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    include-all: true
    filter: "(?i)🇸🇬|SG|Sing|sing|新加坡|狮城|沪新|京新|深新|杭新|广新"

  - name: 新加坡AI
    type: fallback
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    include-all: true
    filter: "(?i)新加坡.*[Gg][Ee][Mm][Ii][Nn][Ii]|[Gg][Ee][Mm][Ii][Nn][Ii].*新加坡"

  - name: 韩国节点
    type: url-test
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    include-all: true
    filter: "(?i)🇰🇷|KR|Korea|korea|KOR|韩国|首尔|韩|韓|春川"

  - name: 美国节点
    type: url-test
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    tolerance: 50
    include-all: true
    filter: "(?i)🇺🇸|US|USA|America|america|United States|美国|凤凰城|洛杉矶|西雅图|芝加哥|纽约|沪美|美"

  - name: 住宅IP
    type: fallback
    url: "http://www.gstatic.com/generate_204"
    interval: 600
    include-all: true
    filter: "住宅"


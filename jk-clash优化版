# ========================
# 内置代理节点
# ========================
proxies:
  - {name: 直连, type: direct}
  - {name: 拒绝, type: reject}

# ========================
# 网络端口配置
# ========================
port: 7890              # HTTP 代理端口
socks-port: 7891        # SOCKS5 代理端口
redir-port: 7892        # 重定向端口
mixed-port: 7893        # 混合代理端口
tproxy-port: 7895       # TProxy 端口

allow-lan: true         # 允许局域网连接
mode: rule              # 运行模式: rule/global/direct
log-level: info         # 日志级别: silent/error/warning/info/debug

# ========================
# Web UI 管理界面
# ========================
external-controller: 0.0.0.0:9090
external-ui: ui
external-ui-name: zashboard
external-ui-url: "https://github.moeyy.xyz/https://github.com/Zephyruso/zashboard/archive/refs/heads/gh-pages.zip"
secret: "123456"        # ⚠️ 请修改为安全密码

# ========================
# DNS 配置
# ========================
dns:
  enable: true
  listen: 0.0.0.0:7874
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.20.0.1/16
  nameserver:
    - 223.5.5.5
    - 1.1.1.1
    - 8.8.8.8

  fallback: 
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query

  fallback-filter:
    geoip: true
    geoip-code: CN

  fake-ip-filter:
    - +.lan
    - +.local
    - geosite:cn
    # 自定义过滤域名
    - +.mitce.net
    - +.ddns-link-b5.uk
    - +.dexlos.com

ipv6: true              # 启用 IPv6 支持

# ========================
# TUN 模式配置
# ========================
tun:
  enable: true
  stack: gvisor           # 网络栈: system/gvisor/lwip
  device: utun
  endpoint-independent-nat: true
  auto-route: false
  auto-detect-interface: false
  auto-redirect: false
  strict-route: false

# ========================
# 配置文件设置
# ========================
profile:
  store-selected: true    # 存储策略组选择
  store-fake-ip: true     # 存储 fake-ip

# ========================
# 嗅探（新增）
# ========================
sniffer:
  enable: true
  sniff:
    TLS:
      ports: [443, 8443]
    HTTP:
      ports: [80, 8080]

# ========================
# 策略组模板定义
# ========================
default: &default
  type: select
  proxies:
    - 直连
    - 所有-手动
    - 所有-自动
    - 住宅-故转
    - 香港-故转
    - 香港-自动
    - 台湾-故转
    - 日本-故转
    - 日本-自动
    - 新加坡-故转
    - 新加坡AI-自动
    - 韩国-故转
    - 美国-故转
    - 英国-故转
    - 其他-故转
    - 拒绝

# ========================
# 策略组配置
# ========================
proxy-groups:

  # AI 服务策略组
  - name: ChatGPT
    <<: *default
  
  - name: Claude
    <<: *default
  
  - name: Meta AI
    <<: *default
  
  - name: Perplexity
    <<: *default
  
  - name: Gemini
    <<: *default

  # 社交媒体策略组
  - name: Telegram
    <<: *default
  
  - name: Twitter(X)
    <<: *default
  
  - name: WhatsApp
    <<: *default
  
  - name: Facebook
    <<: *default
  
  # 流媒体策略组
  - name: YouTube
    <<: *default
  
  - name: Netflix
    <<: *default
  
  - name: TikTok
    <<: *default
  
  - name: Disney
    <<: *default
  
  - name: HBO
    <<: *default
  
  - name: Spotify
    <<: *default
  
  # 游戏策略组
  - name: Steam
    <<: *default
  
  - name: Game
    <<: *default
  
  # 科技公司策略组
  - name: Google
    <<: *default
  
  - name: Apple
    <<: *default
  
  - name: Microsoft
    <<: *default
  
  - name: Amazon
    <<: *default
  
  - name: GitHub
    <<: *default
  
  # 加密货币策略组
  - name: Crypto
    <<: *default
  
  # 功能性策略组
  - name: Test
    <<: *default
  
  - name: Block
    type: select
    proxies:
      - 拒绝
      - 直连

  # 主要策略组
  - name: 国外
    <<: *default
  
  - name: 国内
    type: select
    proxies:
      - 直连
      - 国外
  
  - name: 其他
    <<: *default

  # 节点选择策略组
  - name: 所有-手动
    type: select
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
  
  - name: 所有-自动
    type: url-test
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    url: "https://www.gstatic.com/generate_204"
    interval: 300
    tolerance: 50
  
  # 地区分组策略组
  - name: 住宅-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)住宅"
    url: "https://www.gstatic.com/generate_204"
    interval: 300

  - name: 香港-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)港|hk|hongkong|hong kong"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  
  - name: 香港-自动
    type: url-test
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)港|hk|hongkong|hong kong"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
    tolerance: 50

  - name: 台湾-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)台|tw|taiwan"
    url: "https://www.gstatic.com/generate_204"
    interval: 300

  
  - name: 日本-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)日本|jp|japan"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  
  - name: 日本-自动
    type: url-test
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)日本|jp|japan"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
    tolerance: 50

  - name: 新加坡-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)新加坡|sg|singapore"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  
  - name: 新加坡AI-自动
    type: url-test
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)^(?=.*新加坡)(?=.*Gemini)"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
    tolerance: 50

  - name: 韩国-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)韩|kr|korea"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  
  - name: 美国-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)美|us|unitedstates|united states"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  
  - name: 英国-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "(?i)英|uk|britain|unitedkingdom|united kingdom"
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  
  - name: 其他-故转
    type: fallback
    use:
      - 魔戒机场
      - 牛逼机场
      - POL机场
    filter: "^(?!.*(港|hk|hongkong|hong kong|台|tw|taiwan|日本|jp|japan|新加坡|sg|singapore|韩|kr|korea|美|us|unitedstates|united states|英|uk|britain|unitedkingdom|united kingdom)).*$"
    url: "https://www.gstatic.com/generate_204"
    interval: 300


  

